# --------------------------------------------------------------------------
# Mastermind Automation Studio — production env file.
#
# Copy to `.env.production` and fill in. Both `api/.env` and root `.env`
# are gitignored; nothing here should ever land on GitHub.
#
# Layout:
#   1. Domains  — what Traefik routes
#   2. Auth     — operator credentials + signing secret
#   3. CORS     — what origins the API trusts
#   4. WhatsApp — Meta Cloud API creds + templates + flow choice
#   5. Misc     — TTLs, rate limits, proxy hops
# --------------------------------------------------------------------------

# ==========================================================================
# 1. Domains (Traefik routes traffic by Host header — these MUST match
#    A/CNAME records on your DNS).
# ==========================================================================
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
AUTH_DOMAIN=auth.yourdomain.com

# ==========================================================================
# 2. Auth seed + session signing.
#    AUTH_USER_ID and AUTH_DEFAULT_PASSWORD are used ONCE, on first boot,
#    to seed data/auth.json. Change the password via Settings → Change
#    Password after first login; the seed values become irrelevant.
#    AUTH_RECOVERY_KEY is the operator's "I lost my password" backdoor —
#    save it offline.
#    SESSION_SECRET is the HMAC key for session tokens. Both Flask
#    processes MUST share this exact value or login will fail in prod.
#    Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# ==========================================================================
AUTH_USER_ID=replace-with-operator-user-id
AUTH_DEFAULT_PASSWORD=change-me-on-first-boot
AUTH_RECOVERY_KEY=MA-XXXX-XXXX-XXXX
SESSION_SECRET=replace-with-48-bytes-of-base64-randomness

# Optional tuning. 24h session TTL is sane for a single-operator deploy.
SESSION_TTL_HOURS=24
MEDIA_URL_TTL_HOURS=168
AUTH_LOGIN_MAX_PER_HOUR=12
AUTH_LOGIN_MAX_PER_USER_PER_HOUR=8
AUTH_RECOVERY_MAX_PER_HOUR=5

# ==========================================================================
# 3. CORS. Must include the frontend origin exactly (no trailing slash,
#    no port unless non-443). Comma-separated for multiple.
# ==========================================================================
CORS_ORIGINS=https://app.yourdomain.com

# Number of trusted reverse-proxy hops. Behind Traefik = 1. Bump if you
# add Cloudflare in front (then 2).
TRUSTED_PROXIES=1
FLASK_ENV=production

# ==========================================================================
# 4. WhatsApp Cloud API.
#    The first four values come from your Meta Business app dashboard:
#      developers.facebook.com → Apps → your app → WhatsApp → API Setup
#    PUBLIC_BASE_URL is the API service's stable URL — Meta hits this
#    for status callbacks + inbound user messages.
# ==========================================================================
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
PUBLIC_BASE_URL=https://api.yourdomain.com

# Which media kind to ship per recipient by default ("image" or "video").
# Per-row override is set when the operator hits Send Media → Image/Video.
WHATSAPP_MEDIA_KIND=image

# ==========================================================================
# 4a. Two-step engagement flow (REQUIRED for the architecture we built).
#     direct    — ship media template directly (Meta filters this for
#                 cold recipients)
#     two-step  — ship a TEXT prompt template first, wait for any inbound
#                 reply, then send the personalised media as freeform
#                 inside the 24-hour customer-service window the reply
#                 opens. This is the path we've been productionising.
# ==========================================================================
WHATSAPP_FLOW=two-step

# Stage 1 — approved TEXT-only template. Body example:
#   "Hi {{1}}, Thanks for your interest 😊 Reply YES to receive your
#    personalised media."
# WHATSAPP_PROMPT_TEMPLATE must be APPROVED in WhatsApp Manager. The
# {{1}} placeholder gets the recipient name from the Sheet.
WHATSAPP_PROMPT_TEMPLATE=promo_media_update_prompt
WHATSAPP_PROMPT_LANG=en
WHATSAPP_PROMPT_BODY_PARAMS={name}

# Stage 2 — media-header templates. Only used as a SAFETY fallback if a
# row somehow lands on direct flow (legacy rows, manual operator
# override). The two-step happy path ships freeform media inside the
# 24h window, no template required.
WHATSAPP_TEMPLATE_IMAGE=promo_media_update
WHATSAPP_TEMPLATE_VIDEO=promo_media_update
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_TEMPLATE_BODY_PARAMS={name}

# ==========================================================================
# 5. ffmpeg discovery. Auto-found on PATH in the container — only set
#    these if you've put a custom build somewhere non-standard.
# ==========================================================================
# FFMPEG_BIN=/usr/bin/ffmpeg
# FFPROBE_BIN=/usr/bin/ffprobe
