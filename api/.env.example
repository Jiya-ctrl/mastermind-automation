# =============================================================================
# api/.env.example
#
# Copy to `api/.env` (gitignored) and fill in real values BEFORE first boot.
# Both api/app.py and api/auth_server.py read this at startup.
#
# DO NOT ship api/.env with real values committed. The placeholders below
# trigger a loud warning at boot if any production deploy still uses them.
# =============================================================================

# ------------------------------------------------------------------
# Auth seed — read ONCE on first boot to mint the operator credential.
# After the first boot, data/auth.json owns the live PBKDF2 hash; rotating
# these vars does NOT change the live password (use the in-app
# Settings → Change Password flow for that).
# ------------------------------------------------------------------
AUTH_USER_ID=replace-with-operator-user-id
AUTH_DEFAULT_PASSWORD=replace-with-strong-password
AUTH_RECOVERY_KEY=MA-XXXX-XXXX-XXXX

# ------------------------------------------------------------------
# Session signing secret — REQUIRED. Both auth_server.py (which mints
# session tokens) and app.py (which verifies them) MUST share the same
# value or login tokens won't unlock the main API.
#
# Generate a 48-byte URL-safe random string with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Dev:  leave blank and each process auto-generates its own random secret
#       (a warning prints; tokens won't cross between processes until you
#       set a real shared value here).
# Prod: app.py REFUSES to start without this when FLASK_ENV=production.
# ------------------------------------------------------------------
SESSION_SECRET=replace-with-48-byte-random-base64url

# ------------------------------------------------------------------
# CORS origin whitelist — comma-separated allowed origins for both Flask
# processes. Defaults to the Vite dev server only.
# Production deploys MUST set this to the real frontend host. Example:
#   CORS_ORIGINS=https://app.mastermind-abacus.com
# ------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------
# Environment marker — when set to "production", the session module
# refuses to fall back to a random per-process secret. Leave empty for
# dev. Flask's own FLASK_ENV is honoured.
# ------------------------------------------------------------------
# FLASK_ENV=production

# ------------------------------------------------------------------
# Session TTL (hours) — how long a login lasts before the user must
# re-authenticate. Defaults to 24h. Production deploys with sensitive
# data may want 8h or shorter.
# ------------------------------------------------------------------
# SESSION_TTL_HOURS=24

# ------------------------------------------------------------------
# Media URL TTL (hours) — how long a signed `/files/*` URL stays valid.
# Defaults to 168h (7 days) so WhatsApp's CDN has plenty of window.
# Tighten only if you're sure no downstream cache will hold the URL
# longer than the value here.
# ------------------------------------------------------------------
# MEDIA_URL_TTL_HOURS=168

# ------------------------------------------------------------------
# Rate-limit ceilings — sliding 1-hour window. Defaults are generous
# for single-operator dev; production should tighten. The per-USER
# limit guards against rotating-proxy abuse that bypasses per-IP.
# ------------------------------------------------------------------
# AUTH_LOGIN_MAX_PER_HOUR=12
# AUTH_LOGIN_MAX_PER_USER_PER_HOUR=8
# AUTH_RECOVERY_MAX_PER_HOUR=5

# ------------------------------------------------------------------
# Reverse-proxy hop count — how many trusted proxies sit in front of
# the Flask processes. 1 = a single nginx/Caddy/Cloudflare in front.
# Used by ProxyFix to know how far back to trust X-Forwarded-* headers.
# ------------------------------------------------------------------
# TRUSTED_PROXIES=1

# ------------------------------------------------------------------
# External tool paths (video generator) — leave unset to auto-discover
# ffmpeg / ffprobe via PATH. Override only if your install puts them in
# a non-standard location.
# ------------------------------------------------------------------
# FFMPEG_BIN=/usr/local/bin/ffmpeg
# FFPROBE_BIN=/usr/local/bin/ffprobe

# ==================================================================
# WhatsApp Business Cloud API
#
# Set ALL FOUR vars below to make app.py auto-bootstrap the WhatsApp
# provider on startup (instead of the default MockProvider). PUBLIC_BASE_URL
# is the https URL of your /api mount as Meta's CDN will see it — used to
# turn the signed media paths into absolute URLs for the Graph API.
#
# Get these from your Meta Business app:
#   developers.facebook.com → Apps → your app → WhatsApp → API Setup
# ==================================================================
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_ACCESS_TOKEN=EAA...long-system-user-token
# WHATSAPP_APP_SECRET=your-app-secret-32-hex-chars
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=pick-any-strong-string-you-also-paste-into-meta
# WHATSAPP_MEDIA_KIND=video             # or "image"
# PUBLIC_BASE_URL=https://app.mastermind-abacus.com/api

# ==================================================================
# WhatsApp Marketing Template — REQUIRED for business-initiated sends
# ==================================================================
# WhatsApp Cloud API only allows FREEFORM media messages inside the
# 24-hour customer-service window (i.e. the recipient messaged you in
# the last 24h). Sending freeform to a cold recipient gets rejected:
#   131047 "Re-engagement message"
#   131049 "This message was not delivered to maintain healthy
#          ecosystem engagement."
# The fix is to send an APPROVED Marketing template with a media header.
#
# Operator steps (one-time per template, ~10 min each):
#   1. WhatsApp Manager → Account Tools → Message Templates → Create
#   2. Category: Marketing.  Name: e.g. "promo_render_image".
#      Language: en (or your registered language).
#   3. Header: type IMAGE (or VIDEO for the video template).
#      Upload a sample image/video for Meta's review.
#   4. Body: short marketing copy. Use {{1}}, {{2}} placeholders if you
#      want to inject {name}/{address}/{phone} per recipient.
#   5. Submit → Meta usually approves in minutes for simple templates.
#   6. Once status = Approved, set the env var below to the template name.
#
# Without these env vars the provider falls back to freeform and the
# rejections above will keep happening.
# WHATSAPP_TEMPLATE_IMAGE=promo_render_image
# WHATSAPP_TEMPLATE_VIDEO=promo_render_video
# WHATSAPP_TEMPLATE_LANG=en                          # language registered for the template
# WHATSAPP_TEMPLATE_BODY_PARAMS={name},{address}     # comma-separated, optional; supports {name}/{address}/{phone}
