# Frontend environment template — copy to `frontend/.env.local` and fill in.
#
# These are baked into the bundle at build time, so any value that depends
# on the deployment environment (URL of the API, URL of the auth server,
# brand name overrides) belongs here.

# Main Flask backend — `/generate-jobs`, `/deliveries`, `/list-generated`, etc.
# Default (dev): http://localhost:5000
VITE_API_BASE=http://localhost:5000

# Separate auth Flask server — `/auth/login`, `/auth/verify-recovery`, etc.
# Default (dev): http://localhost:5001
VITE_AUTH_API=http://localhost:5001
